datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

// User Role representation
enum Role {
  ADMIN
  CUSTOMER
}

// Order fulfillment progress indicators
enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

// Allowed transactional channels
enum PaymentMethod {
  STRIPE
  COD
}

model User {
  id        String   @id @default(uuid())
  name      String?
  email     String   @unique
  password  String? // Nullable to support Google OAuth alongside Credentials login
  role      Role     @default(CUSTOMER)
  address   String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders    Order[]
}

model Category {
  id       String    @id @default(uuid())
  name     String
  slug     String    @unique
  products Product[]
}

model Product {
  id          String      @id @default(uuid())
  name        String
  slug        String      @unique
  description String
  price       Float
  stock       Int
  images      String[] // Dynamic array supporting multi-image upload from Cloudinary
  categoryId  String
  category    Category    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  orderItems  OrderItem[]
}

model Order {
  id            String        @id @default(uuid())
  userId        String?
  user          User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  status        OrderStatus   @default(PENDING)
  paymentMethod PaymentMethod
  total         Float
  address       String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  items         OrderItem[]
}

model OrderItem {
  id              String   @id @default(uuid())
  orderId         String
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId       String?
  product         Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  qty             Int
  priceAtPurchase Float // Captures structural cost at checkout, shielding history from catalog shifts
}
